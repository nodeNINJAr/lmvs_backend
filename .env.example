# ── Server ──
PORT=4000
NODE_ENV=development

# ── Database ──
MONGODB_URI=mongodb://localhost:27017/lmvs
# Atlas example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lmvs?retryWrites=true&w=majority

# ── Auth (JWT) ──
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=8h

# ── URLs ──
PUBLIC_BASE_URL=http://localhost:4000
FRONTEND_BASE_URL=http://localhost:5173

# ── Cloudinary (file storage) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OpenAI (verification analysis) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini